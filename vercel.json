{
  "version": 2,
  "outputDirectory": "site/shishirr.pro.bd",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
